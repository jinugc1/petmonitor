# Normalize line endings: LF in the repo, native in working copies where
# it matters. Keeps CI (Linux) and Windows checkouts consistent.
* text=auto
*.dart text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.md text eol=lf
*.json text eol=lf
*.ts text eol=lf
*.kt text eol=lf
*.gradle text eol=lf
*.rules text eol=lf
*.xml text eol=lf
*.bat text eol=crlf
*.ps1 text eol=crlf

# Binary
*.png binary
*.jpg binary
*.jks binary
*.p8 binary
